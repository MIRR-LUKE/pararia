##############################################
# PARARIA SaaS v0.2 - Environment Variables
##############################################
#
# Cursor / repo tooling blocks committing `.env*` files in this environment.
# Use this file as the source of truth and create your local `.env.local` from it:
#
#   cp config/env.example .env.local
#

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# OpenAI API Key (used for STT transcription)
OPENAI_API_KEY="sk-REPLACE_ME"

# Optional: legacy/fallback key name (we still read it if OPENAI_API_KEY is not set)
# STT_API_KEY="sk-REPLACE_ME"



