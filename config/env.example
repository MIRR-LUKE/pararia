##############################################
# PARARIA SaaS - Environment Variables
##############################################
#
# このファイルを元に `.env.local` を作ってください。
#

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
# Prisma で direct を使うのは明示 opt-in のときだけ
# PARARIA_USE_DIRECT_DATABASE_URL="1"

# OpenAI API Key
# 会話ログ生成と保護者レポート生成で使います。
OPENAI_API_KEY="sk-REPLACE_ME"
LLM_API_KEY="sk-REPLACE_ME"
MAINTENANCE_SECRET="replace-with-a-long-random-secret"
BLOB_READ_WRITE_TOKEN=""
RUNPOD_API_KEY=""
RUNPOD_WORKER_NAME="pararia-gpu-worker"
# Vercel 上で未設定なら `VERCEL_GIT_COMMIT_SHA` から `:sha-...` を自動採用します。
# 手動固定する場合は publish 済みの sha tag を入れてください。
RUNPOD_WORKER_IMAGE="ghcr.io/mirr-luke/pararia-runpod-worker:sha-REPLACE_WITH_COMMIT"
RUNPOD_WORKER_CONTAINER_REGISTRY_AUTH_ID=""
RUNPOD_WORKER_GPU="NVIDIA GeForce RTX 3090"
RUNPOD_WORKER_SECURE_CLOUD=0
RUNPOD_WORKER_CONTAINER_DISK_GB=30
RUNPOD_WORKER_VOLUME_GB=0
RUNPOD_WORKER_GPU_COUNT=1

# inline: web app がその場で処理 / external: Runpod worker が取りに行く
PARARIA_BACKGROUND_MODE="external"
PARARIA_AUDIO_STORAGE_MODE="blob"
PARARIA_AUDIO_BLOB_ACCESS="private"
NEXT_PUBLIC_AUDIO_STORAGE_MODE="blob"
NEXT_PUBLIC_APP_URL="https://app.example.com"

# faster-whisper worker
FASTER_WHISPER_PYTHON="python"
FASTER_WHISPER_MODEL="large-v3"
FASTER_WHISPER_DEVICE="auto"
# 3090 / 4090 では int8_float16 系へ自動で寄せる
FASTER_WHISPER_COMPUTE_TYPE="auto"
FASTER_WHISPER_CPU_COMPUTE_TYPE="int8"
FASTER_WHISPER_LIBRARY_PATH=""
FASTER_WHISPER_REQUIRE_CUDA=1
FASTER_WHISPER_BEAM_SIZE=1
FASTER_WHISPER_BATCH_SIZE=16
FASTER_WHISPER_VAD_FILTER=1
FASTER_WHISPER_VAD_MIN_SILENCE_MS=1000
FASTER_WHISPER_VAD_SPEECH_PAD_MS=400
FASTER_WHISPER_VAD_THRESHOLD=0.5
FASTER_WHISPER_VAD_MIN_SPEECH_MS=
FASTER_WHISPER_CONDITION_ON_PREVIOUS_TEXT=1
FASTER_WHISPER_CHUNKING_ENABLED=0
FASTER_WHISPER_POOL_SIZE=1

# Runpod worker loop
# external mode では Runpod は STT 専用。面談ログ/メモ生成は web 側で続行します。
RUNPOD_WORKER_SESSION_PART_LIMIT=8
RUNPOD_WORKER_SESSION_PART_CONCURRENCY=1
RUNPOD_WORKER_CONVERSATION_LIMIT=0
RUNPOD_WORKER_CONVERSATION_CONCURRENCY=1
RUNPOD_WORKER_IDLE_WAIT_MS=2500
RUNPOD_WORKER_ACTIVE_WAIT_MS=200
RUNPOD_WORKER_AUTO_STOP_IDLE_MS=60000
RUNPOD_WORKER_ONLY_SESSION_ID=""
RUNPOD_WORKER_ONLY_CONVERSATION_ID=""
