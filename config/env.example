##############################################
# PARARIA SaaS - Environment Variables
##############################################
#
# このファイルを元に `.env.local` を作ってください。
#

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# OpenAI API Key
# 会話ログ生成と保護者レポート生成で使います。
OPENAI_API_KEY="sk-REPLACE_ME"
LLM_API_KEY="sk-REPLACE_ME"
BLOB_READ_WRITE_TOKEN=""

# inline: web app がその場で処理 / external: local GPU worker が取りに行く
PARARIA_BACKGROUND_MODE="inline"
PARARIA_AUDIO_STORAGE_MODE="local"
PARARIA_AUDIO_BLOB_ACCESS="private"
NEXT_PUBLIC_AUDIO_STORAGE_MODE="local"

# Local faster-whisper worker
FASTER_WHISPER_PYTHON="python"
FASTER_WHISPER_MODEL="large-v3"
FASTER_WHISPER_DEVICE="auto"
FASTER_WHISPER_COMPUTE_TYPE="auto"
FASTER_WHISPER_CPU_COMPUTE_TYPE="int8"
FASTER_WHISPER_LIBRARY_PATH=""
FASTER_WHISPER_REQUIRE_CUDA=1
FASTER_WHISPER_BEAM_SIZE=5
FASTER_WHISPER_BATCH_SIZE=8
FASTER_WHISPER_VAD_FILTER=1
FASTER_WHISPER_CONDITION_ON_PREVIOUS_TEXT=1
FASTER_WHISPER_CHUNKING_ENABLED=0
FASTER_WHISPER_POOL_SIZE=1

# Local GPU worker loop
LOCAL_GPU_WORKER_SESSION_PART_LIMIT=8
LOCAL_GPU_WORKER_SESSION_PART_CONCURRENCY=1
LOCAL_GPU_WORKER_CONVERSATION_LIMIT=6
LOCAL_GPU_WORKER_CONVERSATION_CONCURRENCY=2
LOCAL_GPU_WORKER_IDLE_WAIT_MS=2500
LOCAL_GPU_WORKER_ACTIVE_WAIT_MS=200
