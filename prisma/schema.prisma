generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id            String            @id @default(cuid())
  name          String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  conversations ConversationLog[]
  reports       Report[]
  students      Student[]
  users         User[]
}

model User {
  id             String            @id @default(cuid())
  organizationId String
  email          String            @unique
  passwordHash   String
  name           String
  role           UserRole          @default(TEACHER)
  conversations  ConversationLog[]
  organization   Organization      @relation(fields: [organizationId], references: [id])
}

model Student {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  grade          String?
  course         String?
  enrollmentDate DateTime?
  birthdate      DateTime?
  guardianNames  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  conversations  ConversationLog[]
  reports        Report[]
  organization   Organization      @relation(fields: [organizationId], references: [id])
  profiles       StudentProfile[]
}

model StudentProfile {
  id               String   @id @default(cuid())
  studentId        String
  summary          String?
  personality      String?
  learningStyle    String?
  motivationSource String?
  ngApproach       String?
  profileData      Json?
  basicData        Json?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
  student          Student  @relation(fields: [studentId], references: [id])
}

model ConversationLog {
  id                  String                 @id @default(cuid())
  organizationId      String
  studentId           String
  userId              String?
  sourceType          ConversationSourceType
  summary             String                 @default("")
  keyQuotes           Json?
  keyTopics           Json?
  nextActions         Json?
  structuredDelta     Json?
  createdAt           DateTime               @default(now())
  timeSections        Json?
  extractError        String?
  extractStatus       JobStatus              @default(PENDING)
  extractUpdatedAt    DateTime?
  rawSegments         Json?
  rawTextCleaned      String                 @default("")
  rawTextOriginal     String                 @default("")
  summaryError        String?
  summaryStatus       JobStatus              @default(PENDING)
  summaryUpdatedAt    DateTime?
  formattedTranscript String?
  timeline            Json?
  title               String?
  jobs                ConversationJob[]
  organization        Organization           @relation(fields: [organizationId], references: [id])
  student             Student                @relation(fields: [studentId], references: [id])
  user                User?                  @relation(fields: [userId], references: [id])
}

model ConversationJob {
  id             String              @id @default(cuid())
  conversationId String
  type           ConversationJobType
  status         JobStatus           @default(PENDING)
  attempts       Int                 @default(0)
  lastError      String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  conversation   ConversationLog     @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, type])
  @@index([status, type])
}

model Report {
  id             String       @id @default(cuid())
  studentId      String
  organizationId String
  markdown       String
  json           Json?
  pdfBase64      String?
  periodFrom     DateTime?
  periodTo       DateTime?
  sourceLogIds   Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  TEACHER
}

enum ConversationSourceType {
  MANUAL
  AUDIO
}

enum ConversationJobType {
  SUMMARY
  EXTRACT
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}
