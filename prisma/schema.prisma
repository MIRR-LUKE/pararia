generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  students           Student[]
  conversations      ConversationLog[]
  reports            Report[]
  Session            Session[]
  recordingLocks     StudentRecordingLock[]
  invitations        OrganizationInvitation[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  passwordHash   String
  name           String
  role           UserRole @default(TEACHER)

  organization       Organization           @relation(fields: [organizationId], references: [id])
  conversations      ConversationLog[]
  sessions           Session[]
  reportsSent        Report[]               @relation("ReportSentBy")
  recordingLocksHeld StudentRecordingLock[] @relation("RecordingLockHolder")
  invitationsCreated OrganizationInvitation[] @relation("InvitationCreator")
}

model Student {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  nameKana       String?
  grade          String?
  course         String?
  enrollmentDate DateTime?
  birthdate      DateTime?
  guardianNames  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id])
  conversations ConversationLog[]
  sessions      Session[]
  profiles      StudentProfile[]
  reports       Report[]
  recordingLock StudentRecordingLock?

  @@index([organizationId, createdAt])
}

/// 1 生徒につき同時 1 録音のみ（heartbeat + 自動失効）
model StudentRecordingLock {
  studentId       String            @id
  organizationId  String
  lockedByUserId  String
  lockTokenHash   String
  mode            RecordingLockMode
  lastHeartbeatAt DateTime          @default(now())
  expiresAt       DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lockedBy     User         @relation("RecordingLockHolder", fields: [lockedByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expiresAt])
}

/// 公開サインアップなし — 管理者が発行する招待
model OrganizationInvitation {
  id              String    @id @default(cuid())
  organizationId  String
  email           String
  role            UserRole  @default(TEACHER)
  tokenHash       String    @unique
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitationCreator", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, acceptedAt])
  @@index([email, organizationId])
}

model StudentProfile {
  id               String   @id @default(cuid())
  studentId        String
  summary          String?
  personality      String?
  learningStyle    String?
  motivationSource String?
  ngApproach       String?
  profileData      Json?
  basicData        Json?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model ConversationLog {
  id             String                 @id @default(cuid())
  organizationId String
  studentId      String
  userId         String?
  sessionId      String?                @unique
  sourceType     ConversationSourceType
  status         ConversationStatus     @default(PROCESSING)

  // --- Raw transcript storage (TTL) ---
  rawTextOriginal  String?
  rawTextCleaned   String?
  rawSegments      Json?
  rawTextExpiresAt DateTime?

  // --- LLM outputs (final artifacts) ---
  summaryMarkdown      String?
  timelineJson         Json?
  nextActionsJson      Json?
  profileDeltaJson     Json?
  parentPackJson       Json?
  studentStateJson     Json?
  topicSuggestionsJson Json?
  quickQuestionsJson   Json?
  profileSectionsJson  Json?
  observationJson      Json?
  lessonReportJson     Json?
  formattedTranscript  String?
  chunkAnalysisJson    Json?
  qualityMetaJson      Json?

  createdAt DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id])
  student      Student           @relation(fields: [studentId], references: [id])
  user         User?             @relation(fields: [userId], references: [id])
  session      Session?          @relation(fields: [sessionId], references: [id])
  jobs         ConversationJob[]

  @@index([studentId, createdAt])
  @@index([organizationId, createdAt])
  @@index([rawTextExpiresAt])
}

model ConversationJob {
  id             String              @id @default(cuid())
  conversationId String
  type           ConversationJobType
  status         JobStatus           @default(QUEUED)
  model          String?
  attempts       Int                 @default(0)
  lastError      String?
  outputJson     Json?
  costMetaJson   Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  conversation ConversationLog @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, type])
  @@index([status, type])
  @@index([conversationId, type, status])
}

model Report {
  id                String       @id @default(cuid())
  studentId         String
  organizationId    String
  reportMarkdown    String
  reportJson        Json?
  status            ReportStatus @default(DRAFT)
  reviewedAt        DateTime?
  sentAt            DateTime?
  sentByUserId      String?
  deliveryChannel   String?
  qualityChecksJson Json?
  periodFrom        DateTime?
  periodTo          DateTime?
  sourceLogIds      Json?
  previousReportId  String?
  createdAt         DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  sentBy       User?        @relation("ReportSentBy", fields: [sentByUserId], references: [id])

  previousReport Report?  @relation("ReportPrevious", fields: [previousReportId], references: [id])
  nextReports    Report[] @relation("ReportPrevious")

  @@index([studentId, createdAt])
  @@index([organizationId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  createdAt DateTime @default(now())
}

model Session {
  id                 String        @id @default(cuid())
  organizationId     String
  studentId          String
  userId             String?
  type               SessionType
  status             SessionStatus @default(DRAFT)
  title              String?
  notes              String?
  sessionDate        DateTime      @default(now())
  heroStateLabel     String?
  heroOneLiner       String?
  latestSummary      String?
  completedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  student      Student          @relation(fields: [studentId], references: [id])
  user         User?            @relation(fields: [userId], references: [id])
  parts        SessionPart[]
  conversation ConversationLog?

  @@index([studentId, sessionDate])
  @@index([organizationId, sessionDate])
  @@index([status, type])
}

model SessionPart {
  id                  String                 @id @default(cuid())
  sessionId           String
  partType            SessionPartType
  sourceType          ConversationSourceType @default(AUDIO)
  status              SessionPartStatus      @default(PENDING)
  fileName            String?
  mimeType            String?
  byteSize            Int?
  storageUrl          String?
  rawTextOriginal     String?
  rawTextCleaned      String?
  rawSegments         Json?
  qualityMetaJson     Json?
  transcriptExpiresAt DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, partType])
  @@index([sessionId, status])
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  INSTRUCTOR
}

enum RecordingLockMode {
  INTERVIEW
  LESSON_REPORT
}

enum ConversationSourceType {
  MANUAL
  AUDIO
}

enum ConversationJobType {
  CHUNK_ANALYZE
  REDUCE
  FINALIZE
  FORMAT
  REPORT
}

enum JobStatus {
  RUNNING
  QUEUED
  DONE
  ERROR
}

enum ConversationStatus {
  PROCESSING
  PARTIAL
  DONE
  ERROR
}

enum SessionType {
  INTERVIEW
  LESSON_REPORT
}

enum SessionStatus {
  DRAFT
  COLLECTING
  PROCESSING
  READY
  ERROR
}

enum SessionPartType {
  FULL
  CHECK_IN
  CHECK_OUT
  TEXT_NOTE
}

enum SessionPartStatus {
  PENDING
  UPLOADING
  TRANSCRIBING
  READY
  ERROR
}

enum ReportStatus {
  DRAFT
  REVIEWED
  SENT
}
