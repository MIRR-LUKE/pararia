generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  students      Student[]
  conversations ConversationLog[]
  reports       Report[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  passwordHash   String
  name           String
  role           UserRole @default(TEACHER)

  organization  Organization   @relation(fields: [organizationId], references: [id])
  conversations ConversationLog[]
}

model Student {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  nameKana       String?
  grade          String?
  course         String?
  enrollmentDate DateTime?
  birthdate      DateTime?
  guardianNames  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id])
  conversations ConversationLog[]
  profiles       StudentProfile[]
  reports        Report[]
}

model StudentProfile {
  id               String   @id @default(cuid())
  studentId        String
  summary          String?
  personality      String?
  learningStyle    String?
  motivationSource String?
  ngApproach       String?
  profileData      Json?
  basicData        Json?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model ConversationLog {
  id              String             @id @default(cuid())
  organizationId  String
  studentId       String
  userId          String?
  sourceType      ConversationSourceType
  status          ConversationStatus @default(PROCESSING)

  // --- Raw transcript storage (TTL) ---
  rawTextOriginal  String?
  rawTextCleaned   String?
  rawSegments      Json?
  rawTextExpiresAt DateTime?

  // --- LLM outputs (final artifacts) ---
  summaryMarkdown     String?
  timelineJson        Json?
  nextActionsJson     Json?
  profileDeltaJson    Json?
  formattedTranscript String?
  qualityMetaJson     Json?

  createdAt DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id])
  student      Student        @relation(fields: [studentId], references: [id])
  user         User?          @relation(fields: [userId], references: [id])
  jobs         ConversationJob[]
}

model ConversationJob {
  id             String              @id @default(cuid())
  conversationId String
  type           ConversationJobType
  status         JobStatus           @default(QUEUED)
  model          String?
  attempts       Int                 @default(0)
  lastError      String?
  outputJson     Json?
  costMetaJson   Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  conversation ConversationLog @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, type])
  @@index([status, type])
}

model Report {
  id               String   @id @default(cuid())
  studentId        String
  organizationId   String
  reportMarkdown   String
  reportJson       Json?
  reportPdfBase64  String?
  periodFrom       DateTime?
  periodTo         DateTime?
  sourceLogIds     Json?
  previousReportId String?
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  previousReport Report?  @relation("ReportPrevious", fields: [previousReportId], references: [id])
  nextReports    Report[] @relation("ReportPrevious")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  TEACHER
}

enum ConversationSourceType {
  MANUAL
  AUDIO
}

enum ConversationJobType {
  SUMMARY
  EXTRACT
  MERGE
  FORMAT
  REPORT
}

enum JobStatus {
  RUNNING
  QUEUED
  DONE
  ERROR
}

enum ConversationStatus {
  PROCESSING
  PARTIAL
  DONE
  ERROR
}
