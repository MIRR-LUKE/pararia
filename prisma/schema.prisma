generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  planCode  String   @default("standard")
  contractStatus String @default("active")
  contractRenewalDate DateTime?
  billingContactName String?
  billingContactEmail String?
  salesOwnerName String?
  csOwnerName String?
  usageLimitNote String?
  supportNote String?
  studentLimit Int?
  defaultLocale String @default("ja-JP")
  defaultTimeZone String @default("Asia/Tokyo")
  guardianConsentRequired Boolean @default(true)
  consentVersion String?
  consentUpdatedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  students           Student[]
  conversations      ConversationLog[]
  reports            Report[]
  reportDeliveryEvents ReportDeliveryEvent[]
  Session            Session[]
  recordingLocks     StudentRecordingLock[]
  invitations        OrganizationInvitation[]
  properNounGlossaryEntries ProperNounGlossaryEntry[]
  properNounSuggestions     ProperNounSuggestion[]
  nextMeetingMemos          NextMeetingMemo[]
  teacherRecordingSessions  TeacherRecordingSession[]
  teacherRecordingJobs      TeacherRecordingJob[]
  teacherAppDevices         TeacherAppDevice[]
  teacherAppAuthSessions    TeacherAppDeviceAuthSession[]

  @@index([contractStatus, updatedAt])
  @@index([planCode, updatedAt])
  @@index([updatedAt, createdAt])
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  passwordHash   String
  name           String
  role           UserRole @default(TEACHER)

  organization       Organization           @relation(fields: [organizationId], references: [id])
  conversations      ConversationLog[]
  sessions           Session[]
  reportsSent        Report[]               @relation("ReportSentBy")
  deletedConversations ConversationLog[]    @relation("ConversationDeletedBy")
  deletedReports     Report[]               @relation("ReportDeletedBy")
  reportDeliveryEventsActed ReportDeliveryEvent[] @relation("ReportDeliveryEventActor")
  recordingLocksHeld StudentRecordingLock[] @relation("RecordingLockHolder")
  invitationsCreated OrganizationInvitation[] @relation("InvitationCreator")
  properNounGlossaryEntries ProperNounGlossaryEntry[] @relation("GlossaryTutor")
  teacherRecordingSessionsCreated TeacherRecordingSession[] @relation("TeacherRecordingCreator")
  teacherAppDevicesConfigured TeacherAppDevice[] @relation("TeacherAppDeviceConfiguredBy")
  teacherAppAuthSessions       TeacherAppDeviceAuthSession[]

  @@index([organizationId, role])
}

model PlatformOperator {
  id             String       @id @default(cuid())
  email          String       @unique
  displayName    String?
  role           PlatformRole @default(CUSTOMER_SUCCESS)
  disabledAt     DateTime?
  lastSignedInAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  auditLogs PlatformAuditLog[] @relation("PlatformAuditActor")

  @@index([role, disabledAt])
  @@index([disabledAt, updatedAt])
}

model PlatformAuditLog {
  id                   String   @id @default(cuid())
  actorOperatorId      String?
  action               String
  status               String   @default("SUCCESS")
  reason               String?
  riskLevel            String   @default("LOW")
  targetType           String?
  targetId             String?
  targetOrganizationId String?
  requestId            String?
  requestIpHash        String?
  userAgentHash        String?
  beforeJson           Json?
  afterJson            Json?
  metadataJson         Json?
  createdAt            DateTime @default(now())

  actorOperator PlatformOperator? @relation("PlatformAuditActor", fields: [actorOperatorId], references: [id], onDelete: SetNull)

  @@index([actorOperatorId, createdAt])
  @@index([targetOrganizationId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
  @@index([status, createdAt])
}

model Student {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  nameKana       String?
  grade          String?
  course         String?
  enrollmentDate DateTime?
  birthdate      DateTime?
  guardianNames  String?
  archivedAt     DateTime?
  archivedByUserId String?
  archiveReason  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id])
  conversations ConversationLog[]
  sessions      Session[]
  profiles      StudentProfile[]
  reports       Report[]
  reportDeliveryEvents ReportDeliveryEvent[]
  recordingLock StudentRecordingLock?
  properNounGlossaryEntries ProperNounGlossaryEntry[]
  properNounSuggestions     ProperNounSuggestion[]
  nextMeetingMemos          NextMeetingMemo[]
  teacherRecordingSelections TeacherRecordingSession[] @relation("TeacherRecordingSelectedStudent")

  @@index([organizationId, archivedAt, createdAt])
  @@index([organizationId, archivedAt, name])
}

/// 1 生徒につき同時 1 録音のみ（heartbeat + 自動失効）
model StudentRecordingLock {
  studentId       String            @id
  organizationId  String
  lockedByUserId  String
  lockTokenHash   String
  mode            RecordingLockMode
  lastHeartbeatAt DateTime          @default(now())
  expiresAt       DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lockedBy     User         @relation("RecordingLockHolder", fields: [lockedByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expiresAt])
}

/// 公開サインアップなし — 管理者が発行する招待
model OrganizationInvitation {
  id              String    @id @default(cuid())
  organizationId  String
  email           String
  role            UserRole  @default(TEACHER)
  tokenHash       String    @unique
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitationCreator", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, acceptedAt])
  @@index([organizationId, acceptedAt, expiresAt])
  @@index([email, organizationId])
}

model StudentProfile {
  id               String   @id @default(cuid())
  studentId        String
  summary          String?
  personality      String?
  learningStyle    String?
  motivationSource String?
  ngApproach       String?
  profileData      Json?
  basicData        Json?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model ConversationLog {
  id             String                 @id @default(cuid())
  organizationId String
  studentId      String
  userId         String?
  sessionId      String?                @unique
  deletedSessionId String?
  sourceType     ConversationSourceType
  status         ConversationStatus     @default(PROCESSING)
  deletedAt      DateTime?
  deletedByUserId String?
  deletedReason  String?

  // --- Raw transcript storage (TTL) ---
  rawTextOriginal  String?
  // legacy column name: keeps display / preview transcript after lightweight cleanup
  rawTextCleaned   String?
  reviewedText     String?
  reviewState      TranscriptReviewState @default(NONE)
  rawSegments      Json?
  rawTextExpiresAt DateTime?
  processingLeaseExecutionId String?
  processingLeaseExpiresAt DateTime?
  processingLeaseStartedAt DateTime?
  processingLeaseHeartbeatAt DateTime?

  // --- LLM outputs (final artifacts) ---
  artifactJson          Json?
  summaryMarkdown      String?
  formattedTranscript  String?
  qualityMetaJson      Json?

  createdAt DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id])
  student      Student           @relation(fields: [studentId], references: [id])
  user         User?             @relation(fields: [userId], references: [id])
  session      Session?          @relation(fields: [sessionId], references: [id])
  deletedBy    User?             @relation("ConversationDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  jobs         ConversationJob[]
  properNounSuggestions ProperNounSuggestion[]
  nextMeetingMemo NextMeetingMemo?

  @@index([studentId, createdAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, deletedAt, createdAt])
  @@index([studentId, deletedAt, createdAt])
  @@index([rawTextExpiresAt])
  @@index([status, processingLeaseExpiresAt])
  @@index([organizationId, processingLeaseExpiresAt])
}

model ConversationJob {
  id             String              @id @default(cuid())
  conversationId String
  type           ConversationJobType
  status         JobStatus           @default(QUEUED)
  executionId    String?
  model          String?
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3)
  lastError      String?
  nextRetryAt    DateTime?
  leaseExpiresAt DateTime?
  lastHeartbeatAt DateTime?
  failedAt       DateTime?
  completedAt    DateTime?
  lastRunDurationMs Int?
  lastQueueLagMs Int?
  outputJson     Json?
  costMetaJson   Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  conversation ConversationLog @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, type])
  @@index([status, type])
  @@index([status, nextRetryAt, type])
  @@index([status, updatedAt, createdAt])
  @@index([status, leaseExpiresAt])
  @@index([status, startedAt])
  @@index([conversationId, type, status])
  @@index([conversationId, leaseExpiresAt])
}

model NextMeetingMemo {
  id              String                @id @default(cuid())
  organizationId  String
  studentId       String
  sessionId       String                @unique
  conversationId  String                @unique
  status          NextMeetingMemoStatus @default(QUEUED)
  previousSummary String?
  suggestedTopics String?
  rawJson         Json?
  model           String?
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student      Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session      Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  conversation ConversationLog @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([organizationId, createdAt])
  @@index([status, updatedAt])
}

model SessionPartJob {
  id            String             @id @default(cuid())
  sessionPartId String
  type          SessionPartJobType
  status        JobStatus          @default(QUEUED)
  attempts      Int                @default(0)
  lastError     String?
  outputJson    Json?
  costMetaJson  Json?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  sessionPart SessionPart @relation(fields: [sessionPartId], references: [id], onDelete: Cascade)

  @@unique([sessionPartId, type])
  @@index([status, type])
  @@index([status, updatedAt, createdAt])
  @@index([status, startedAt])
  @@index([sessionPartId, type, status])
}

model TeacherAppDevice {
  id                  String                 @id @default(cuid())
  organizationId      String
  configuredByUserId  String
  label               String
  status              TeacherAppDeviceStatus @default(ACTIVE)
  lastClientPlatform  TeacherAppClientPlatform?
  lastAppVersion      String?
  lastBuildNumber     String?
  lastAuthenticatedAt DateTime?
  lastSeenAt          DateTime?
  pushToken           String?
  pushTokenProvider   String?
  pushNotificationPermission String?
  pushTokenUpdatedAt  DateTime?
  lastPushSentAt      DateTime?
  lastPushError       String?
  lastPushErrorAt     DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  organization Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  configuredBy User                         @relation("TeacherAppDeviceConfiguredBy", fields: [configuredByUserId], references: [id], onDelete: Cascade)
  recordings   TeacherRecordingSession[]
  authSessions TeacherAppDeviceAuthSession[]

  @@unique([organizationId, label])
  @@index([organizationId, status, updatedAt])
  @@index([organizationId, status, pushTokenUpdatedAt])
}

model TeacherAppDeviceAuthSession {
  id                    String                           @id @default(cuid())
  organizationId        String
  userId                String
  deviceId              String
  status                TeacherAppDeviceAuthSessionStatus @default(ACTIVE)
  clientPlatform        TeacherAppClientPlatform         @default(UNKNOWN)
  appVersion            String?
  buildNumber           String?
  refreshTokenHash      String
  refreshTokenExpiresAt DateTime
  lastSeenAt            DateTime?
  lastRefreshedAt       DateTime?
  revokedAt             DateTime?
  revokeReason          String?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  device       TeacherAppDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([refreshTokenHash])
  @@index([organizationId, deviceId, status, updatedAt])
  @@index([organizationId, userId, status, updatedAt])
  @@index([refreshTokenExpiresAt])
}

model TeacherRecordingSession {
  id                        String                      @id @default(cuid())
  organizationId            String
  createdByUserId           String
  selectedStudentId         String?
  deviceId                  String?
  deviceLabel               String
  status                    TeacherRecordingSessionStatus @default(RECORDING)
  audioFileName             String?
  audioMimeType             String?
  audioByteSize             Int?
  audioStorageUrl           String?
  durationSeconds           Float?
  transcriptText            String?
  transcriptSegmentsJson    Json?
  transcriptMetaJson        Json?
  suggestedStudentsJson     Json?
  errorMessage              String?
  recordedAt                DateTime?
  uploadedAt                DateTime?
  analyzedAt                DateTime?
  confirmedAt               DateTime?
  promotionTriggeredAt      DateTime?
  promotedSessionId         String?
  promotedConversationId    String?
  processingLeaseExecutionId String?
  processingLeaseExpiresAt  DateTime?
  processingLeaseStartedAt  DateTime?
  processingLeaseHeartbeatAt DateTime?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User               @relation("TeacherRecordingCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  selectedStudent Student?         @relation("TeacherRecordingSelectedStudent", fields: [selectedStudentId], references: [id], onDelete: SetNull)
  device        TeacherAppDevice?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  jobs          TeacherRecordingJob[]

  @@index([organizationId, deviceId, status, createdAt])
  @@index([organizationId, deviceLabel, status, createdAt])
  @@index([organizationId, updatedAt])
  @@index([organizationId, recordedAt])
  @@index([createdByUserId, status, createdAt])
  @@index([selectedStudentId, createdAt])
  @@index([processingLeaseExpiresAt])
}

model TeacherRecordingJob {
  id                 String                 @id @default(cuid())
  recordingSessionId String
  organizationId     String
  type               TeacherRecordingJobType
  status             JobStatus              @default(QUEUED)
  executionId        String?
  attempts           Int                    @default(0)
  maxAttempts        Int                    @default(3)
  lastError          String?
  outputJson         Json?
  costMetaJson       Json?
  startedAt          DateTime?
  finishedAt         DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  recordingSession TeacherRecordingSession @relation(fields: [recordingSessionId], references: [id], onDelete: Cascade)
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([recordingSessionId, type])
  @@index([status, type])
  @@index([organizationId, status, updatedAt, createdAt])
  @@index([organizationId, status, startedAt])
  @@index([recordingSessionId, type, status])
}

model Report {
  id                String       @id @default(cuid())
  studentId         String
  organizationId    String
  reportMarkdown    String
  reportJson        Json?
  status            ReportStatus @default(DRAFT)
  deletedAt         DateTime?
  deletedByUserId   String?
  deletedReason     String?
  reviewedAt        DateTime?
  sentAt            DateTime?
  sentByUserId      String?
  deliveryChannel   String?
  qualityChecksJson Json?
  periodFrom        DateTime?
  periodTo          DateTime?
  sourceLogIds      Json?
  createdAt         DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  sentBy       User?        @relation("ReportSentBy", fields: [sentByUserId], references: [id])
  deletedBy    User?        @relation("ReportDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  deliveryEvents ReportDeliveryEvent[]

  @@index([studentId, createdAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, deletedAt, createdAt])
  @@index([studentId, deletedAt, createdAt])
}

model ProperNounGlossaryEntry {
  id             String         @id @default(cuid())
  organizationId String
  studentId      String?
  tutorUserId    String?
  kind           ProperNounKind @default(OTHER)
  canonicalValue String
  aliasesJson    Json?
  sendToProvider Boolean        @default(false)
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student      Student?     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor        User?        @relation("GlossaryTutor", fields: [tutorUserId], references: [id], onDelete: Cascade)
  suggestions  ProperNounSuggestion[]

  @@index([organizationId, kind])
  @@index([organizationId, sendToProvider])
  @@index([studentId, kind])
  @@index([tutorUserId, kind])
}

model ProperNounSuggestion {
  id              String                     @id @default(cuid())
  organizationId  String
  studentId       String
  sessionId       String?
  sessionPartId   String?
  conversationId  String?
  glossaryEntryId String?
  kind            ProperNounKind            @default(OTHER)
  rawValue        String
  suggestedValue  String
  finalValue      String?
  reason          String
  confidence      Int                        @default(0)
  source          ProperNounSuggestionSource
  status          ProperNounSuggestionStatus @default(PENDING)
  spanJson        Json?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student      Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session      Session?                  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionPart  SessionPart?              @relation(fields: [sessionPartId], references: [id], onDelete: Cascade)
  conversation ConversationLog?          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  glossaryEntry ProperNounGlossaryEntry? @relation(fields: [glossaryEntryId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([studentId, status])
  @@index([sessionPartId, status])
  @@index([conversationId, status])
}

model ReportDeliveryEvent {
  id              String                  @id @default(cuid())
  reportId        String
  organizationId  String
  studentId       String
  actorUserId     String?
  eventType       ReportDeliveryEventType
  deliveryChannel String?
  note            String?
  eventMetaJson   Json?
  createdAt       DateTime                @default(now())

  report        Report        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  actor         User?         @relation("ReportDeliveryEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([reportId, createdAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, eventType, createdAt])
  @@index([studentId, createdAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  targetType     String?
  targetId       String?
  status         String   @default("SUCCESS")
  detailJson     Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([userId, createdAt])
}

model AuthThrottle {
  id             String   @id @default(cuid())
  scope          String
  keyHash        String
  failureCount   Int      @default(0)
  windowStartedAt DateTime
  lastFailureAt  DateTime?
  blockedUntil   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([scope, keyHash])
  @@index([scope, blockedUntil])
}

model BlobUploadReservation {
  id               String   @id @default(cuid())
  organizationId   String
  studentId        String
  sessionId        String
  partType         SessionPartType
  uploadedByUserId String
  uploadSource     String   @default("file_upload")
  pathname         String   @unique
  expectedFileName String?
  expectedMimeType String?
  expectedByteSize Int?
  blobUrl          String?
  blobDownloadUrl  String?
  blobContentType  String?
  blobByteSize     Int?
  status           String   @default("PENDING")
  completedAt      DateTime?
  consumedAt       DateTime?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId, status, expiresAt])
  @@index([sessionId, partType, status])
  @@index([uploadedByUserId, status])
}

model StorageDeletionRequest {
  id            String   @id @default(cuid())
  organizationId String?
  storageUrl    String   @unique
  reason        String
  status        String   @default("PENDING")
  attempts      Int      @default(0)
  lastError     String?
  lastAttemptAt DateTime?
  completedAt   DateTime?
  nextAttemptAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, status, updatedAt])
  @@index([status, updatedAt, createdAt])
}

model ApiThrottleBucket {
  id              String   @id @default(cuid())
  scope           String
  keyHash         String
  requestCount    Int      @default(0)
  byteCount       Int      @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([scope, keyHash])
  @@index([scope, blockedUntil])
}

model IdempotencyRequest {
  id             String   @id @default(cuid())
  scope          String
  keyHash        String
  requestHash    String
  organizationId String?
  userId         String?
  status         String   @default("PENDING")
  responseStatus Int?
  responseBody   Json?
  completedAt    DateTime?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([scope, keyHash])
  @@index([status, expiresAt])
}

model StudentArchiveSnapshot {
  id               String   @id @default(cuid())
  organizationId   String
  studentId        String
  studentName      String
  archivedByUserId String?
  reason           String?
  runtimePathsJson Json?
  snapshotJson     Json
  createdAt        DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([studentId, createdAt])
}

model Session {
  id                 String        @id @default(cuid())
  organizationId     String
  studentId          String
  userId             String?
  type               SessionType
  status             SessionStatus @default(DRAFT)
  title              String?
  notes              String?
  sessionDate        DateTime      @default(now())
  heroStateLabel     String?
  heroOneLiner       String?
  latestSummary      String?
  completedAt        DateTime?
  sessionPartLeaseExecutionId String?
  sessionPartLeaseExpiresAt DateTime?
  sessionPartLeaseStartedAt DateTime?
  sessionPartLeaseHeartbeatAt DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  student      Student          @relation(fields: [studentId], references: [id])
  user         User?            @relation(fields: [userId], references: [id])
  parts        SessionPart[]
  conversation ConversationLog?
  properNounSuggestions ProperNounSuggestion[]
  nextMeetingMemo NextMeetingMemo?

  @@index([studentId, sessionDate])
  @@index([organizationId, sessionDate])
  @@index([status, type])
  @@index([sessionPartLeaseExpiresAt])
}

model SessionPart {
  id                  String                 @id @default(cuid())
  sessionId           String
  partType            SessionPartType
  sourceType          ConversationSourceType @default(AUDIO)
  status              SessionPartStatus      @default(PENDING)
  fileName            String?
  mimeType            String?
  byteSize            Int?
  storageUrl          String?
  rawTextOriginal     String?
  // legacy column name: keeps display / preview transcript after lightweight cleanup
  rawTextCleaned      String?
  reviewedText        String?
  reviewState         TranscriptReviewState @default(NONE)
  rawSegments         Json?
  qualityMetaJson     Json?
  transcriptExpiresAt DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  session Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  jobs    SessionPartJob[]
  properNounSuggestions ProperNounSuggestion[]

  @@unique([sessionId, partType])
  @@index([sessionId, status])
}

