DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pararia"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/pararia"
AUTH_SECRET="replace-with-a-long-random-secret"
OPENAI_API_KEY="your-openai-api-key"
LLM_API_KEY="your-llm-api-key"
NEXT_PUBLIC_APP_NAME="PARARIA AI"
BLOB_READ_WRITE_TOKEN=""
# Needed for `runpod:*` commands and for web-side auto wake in external mode.
RUNPOD_API_KEY=""
RUNPOD_WORKER_NAME="pararia-gpu-worker"
# Vercel 上で未設定なら `VERCEL_GIT_COMMIT_SHA` から `:sha-...` を自動採用します。
# 手動で固定したいときは publish 済みの sha tag を入れてください。
RUNPOD_WORKER_IMAGE="ghcr.io/mirr-luke/pararia-runpod-worker:sha-REPLACE_WITH_COMMIT"
RUNPOD_WORKER_GPU_CANDIDATES="NVIDIA GeForce RTX 5090,NVIDIA GeForce RTX 4090"
# Legacy single-GPU override. When unset, the app tries RUNPOD_WORKER_GPU_CANDIDATES in order.
RUNPOD_WORKER_GPU="NVIDIA GeForce RTX 4090"
RUNPOD_WORKER_SECURE_CLOUD=0
RUNPOD_WORKER_CONTAINER_DISK_GB=30
RUNPOD_WORKER_VOLUME_GB=0
RUNPOD_WORKER_GPU_COUNT=1

# Local runtime storage root.
# Default is .data/ under the repository for backward compatibility.
# Set this to a directory outside the repo if you want uploads/manifests/temp audio fully separated.
# PARARIA_RUNTIME_DIR="../pararia-runtime"

# Background execution
# inline: web app 自体が enqueue 後にそのまま job を処理
# external: web app は enqueue だけ行い、Runpod worker が queue を処理
PARARIA_BACKGROUND_MODE="external"

# Audio storage
# local: repo / runtime 配下へ保存
# blob: Vercel Blob へ保存し、ローカル web / 本番 web と Runpod worker で共有
PARARIA_AUDIO_STORAGE_MODE="blob"
PARARIA_AUDIO_BLOB_ACCESS="private"
NEXT_PUBLIC_AUDIO_STORAGE_MODE="blob"

# Retention / cleanup
PARARIA_TRANSCRIPT_RETENTION_DAYS=30
PARARIA_AUDIO_RETENTION_DAYS=30
PARARIA_REPORT_DELIVERY_EVENT_RETENTION_DAYS=365

# Optional basic auth for preview deployments
# BASIC_AUTH_USER="preview"
# BASIC_AUTH_PASS="replace-me"

# Pipeline tuning
JOB_CONCURRENCY=3
JOB_MAX_ATTEMPTS=3
JOB_LEASE_MS=300000
JOB_RETRY_BASE_MS=15000

# GPT-5 family routing
LLM_MODEL=gpt-5.4
# Conversation draft generation stays on GPT-5.4 even when this is changed to a smaller model.
LLM_MODEL_FAST=gpt-5.4
LLM_MODEL_REPORT=gpt-5.4

# Generation token/time limits
LLM_CALL_TIMEOUT_MS=90000

# Speech to text
# faster-whisper worker
FASTER_WHISPER_PYTHON="python"
FASTER_WHISPER_MODEL="large-v3"
FASTER_WHISPER_DEVICE="auto"
FASTER_WHISPER_COMPUTE_TYPE="auto"
FASTER_WHISPER_CPU_COMPUTE_TYPE="int8"
FASTER_WHISPER_LIBRARY_PATH=""
FASTER_WHISPER_REQUIRE_CUDA=1
FASTER_WHISPER_BEAM_SIZE=5
FASTER_WHISPER_BATCH_SIZE=8
FASTER_WHISPER_VAD_FILTER=1
FASTER_WHISPER_CONDITION_ON_PREVIOUS_TEXT=1
FASTER_WHISPER_CHUNKING_ENABLED=0
FASTER_WHISPER_POOL_SIZE=1

# Runpod worker loop
RUNPOD_WORKER_SESSION_PART_LIMIT=8
RUNPOD_WORKER_SESSION_PART_CONCURRENCY=1
RUNPOD_WORKER_CONVERSATION_LIMIT=6
RUNPOD_WORKER_CONVERSATION_CONCURRENCY=2
RUNPOD_WORKER_IDLE_WAIT_MS=2500
RUNPOD_WORKER_ACTIVE_WAIT_MS=200
RUNPOD_WORKER_AUTO_STOP_IDLE_MS=300000

# Recording validation (lib/recording/validation.ts)
# Minimum audio length (seconds) before STT; both interview & lesson use same gate by default.
RECORDING_MIN_DURATION_SECONDS=60
# Max recording length (seconds)
MAX_INTERVIEW_DURATION_SECONDS=3600
MAX_LESSON_PART_DURATION_SECONDS=600
# Minimum significant characters after STT / manual input before LLM pipeline.
TRANSCRIPT_MIN_SIGNIFICANT_CHARS=35
# If 1, reject upload when audio duration cannot be parsed (default: routes now pass strict mode).
# RECORDING_REQUIRE_KNOWN_DURATION=1

# Invitations (default 7 days)
# INVITATION_EXPIRES_DAYS=7
